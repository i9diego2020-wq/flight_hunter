# Neon.tech PostgreSQL — copie a connection string do painel do Neon
DATABASE_URL=postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech/flight_hunter?sslmode=require

# Telegram Bot — token do BotFather
TELEGRAM_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do seu chat ou grupo no Telegram
# Para um grupo: -100xxxxxxxxxx
# Para seu chat pessoal: seu user ID (consulte @userinfobot)
TELEGRAM_CHAT_ID=123456789

# Configurações opcionais
# Porcentagem abaixo da média para considerar PROMOÇÃO (padrão: 20)
DEAL_THRESHOLD_PERCENT=20
# Porcentagem abaixo da média para considerar BOM PREÇO (padrão: 10)
GOOD_PRICE_THRESHOLD_PERCENT=10
# Número mínimo de amostras para calcular média confiável (padrão: 5)
MIN_SAMPLES_FOR_INTEL=5
